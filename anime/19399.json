      } ],
      "type" : "REGULAR"
    }, {
      "air_date" : "2026-01-26",
      "description" : "Mike is thrilled to be assigned a \"korokke\" case. After work, Fon the ragman drops by. Fon is friendly, but his smile hides a danger that makes even Sero wary of him. On a different day, a suspicious person is caught wandering in front of the company door, but it turns out to be Sero`s younger brother, Luc. But why did he come to the company?\nSource: Crunchyroll",
      "episode_id" : 306000,
      "length" : 25,
      "number" : 4,
      "recap" : false,
      "resources" : {
